NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://clutchboard-alpha-ten.vercel.app

# App mode
ENABLE_MOCK_RIOT=false
DEMO_AUTO_LOGIN=false

# Security
APP_SESSION_SECRET=replace-with-a-long-random-string

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/valorant_tracker?schema=public

# Redis / rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Riot RSO / API
RIOT_API_KEY=replace-with-riot-api-key
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=https://clutchboard-alpha-ten.vercel.app/api/auth/riot/callback
RIOT_RSO_POST_LOGOUT_REDIRECT_URI=https://clutchboard-alpha-ten.vercel.app/login
RIOT_RSO_SCOPES=openid offline_access
RIOT_REGION=europe
RIOT_PLATFORM=eu

# Optional local development callbacks
# RIOT_RSO_REDIRECT_URI=http://localhost:3000/api/auth/riot/callback
# RIOT_RSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login

# Observability
LOG_LEVEL=info
